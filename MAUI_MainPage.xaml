<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalculatriceMargeMAUI.MainPage"
             Title="Calculatrice de Marge"
             BackgroundColor="#E6EAF2">

    <ScrollView Padding="15">
        <VerticalStackLayout Spacing="15">
            <!-- Titre -->
            <Label 
                Text="Calculatrice de Marge"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="#1D3557"
                HorizontalOptions="Center"/>

            <!-- Section Saisies -->
            <Frame BorderColor="#D8DFEC" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Saisies" FontSize="16" FontAttributes="Bold" TextColor="#1F2A44"/>
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Titre" FontSize="12" TextColor="#7F8FA3"/>
                        <Entry x:Name="txtTitre" Placeholder="Sans titre" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Déboursé sec (€)" FontSize="12" TextColor="#7F8FA3"/>
                        <Entry x:Name="txtDebourse" Placeholder="0" Keyboard="Numeric"/>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="FillAndExpand">
                            <Label Text="Frais généraux" FontSize="12" TextColor="#7F8FA3"/>
                            <Entry x:Name="txtFrais" Placeholder="10" Keyboard="Numeric"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="FillAndExpand">
                            <Label Text="Mode" FontSize="12" TextColor="#7F8FA3"/>
                            <Picker x:Name="cmbFraisMode" Title="Mode" SelectedIndex="0">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>%</x:String>
                                        <x:String>EUR</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Prix de vente HT (€)" FontSize="12" TextColor="#7F8FA3"/>
                        <Entry x:Name="txtVente" Placeholder="0" Keyboard="Numeric"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="TVA (%)" FontSize="12" TextColor="#7F8FA3"/>
                        <Entry x:Name="txtTVA" Placeholder="20" Keyboard="Numeric" Text="20"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Boutons d'action -->
            <HorizontalStackLayout Spacing="10">
                <Button 
                    Text="Calculer"
                    BackgroundColor="#2D9CDB"
                    TextColor="White"
                    FontAttributes="Bold"
                    HorizontalOptions="FillAndExpand"
                    Clicked="OnCalculerClicked"/>
                <Button 
                    Text="Réinitialiser"
                    BackgroundColor="#E74C3C"
                    TextColor="White"
                    FontAttributes="Bold"
                    HorizontalOptions="FillAndExpand"
                    Clicked="OnResetClicked"/>
            </HorizontalStackLayout>

            <!-- Récap Rapide -->
            <Frame BorderColor="#D8DFEC" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Récap rapide" FontSize="16" FontAttributes="Bold" TextColor="#1F2A44"/>
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Déboursé sec" FontSize="11" TextColor="#7F8FA3"/>
                            <Label x:Name="txtRecapDS" FontSize="16" FontAttributes="Bold" TextColor="#2D9CDB" Text="-"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Prix HT" FontSize="11" TextColor="#7F8FA3"/>
                            <Label x:Name="txtRecapHT" FontSize="16" FontAttributes="Bold" TextColor="#2D9CDB" Text="-"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="4">
                            <Label Text="Prix TTC" FontSize="11" TextColor="#7F8FA3"/>
                            <Label x:Name="txtRecapTTC" FontSize="16" FontAttributes="Bold" TextColor="#27AE60" Text="-"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Résultats -->
            <Frame BorderColor="#D8DFEC" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Résultats" FontSize="16" FontAttributes="Bold" TextColor="#1F2A44"/>
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Prix de revient (avec frais)" FontSize="11" TextColor="#7F8FA3"/>
                        <Label x:Name="txtPrixRevient" FontSize="14" FontAttributes="Bold" TextColor="#2D9CDB" Text="-"/>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Marge brute" FontSize="11" TextColor="#7F8FA3"/>
                            <Label x:Name="txtMargeBrute" FontSize="14" FontAttributes="Bold" TextColor="#F39C12" Text="-"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Marge nette" FontSize="11" TextColor="#7F8FA3"/>
                            <Label x:Name="txtMargeNette" FontSize="14" FontAttributes="Bold" TextColor="#27AE60" Text="-"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Texte info -->
            <Label 
                Text="Version 1.0.6 MAUI • © 2025 C. Lecomte"
                FontSize="10"
                TextColor="#7F8FA3"
                HorizontalOptions="Center"
                Margin="0,10"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
