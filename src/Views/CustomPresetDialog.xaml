<Window x:Class="CalculatriceMargeWPF.Views.CustomPresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preset personnalisé" Height="220" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F9FB"
        FontFamily="Segoe UI">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="TVA" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#2C3E50"/>
        <TextBox x:Name="txtTva" Grid.Row="0" Grid.Column="1" Margin="0,0,6,6" Height="28"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Frais généraux" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#2C3E50"/>
        <TextBox x:Name="txtFrais" Grid.Row="1" Grid.Column="1" Margin="0,0,6,6" Height="28"/>
        <ComboBox x:Name="cmbMode" Grid.Row="1" Grid.Column="2" Margin="0,0,0,6" Height="28">
            <ComboBoxItem Content="%"/>
            <ComboBoxItem Content="€"/>
        </ComboBox>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Annuler" Width="90" Height="30" Margin="0,0,6,0" Click="Cancel_Click" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Valider" Width="90" Height="30" Click="Ok_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
