<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CalculatriceMargeWPF.Views.MargeViseeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marge Visée - Calcul Inversé" 
        Width="480" 
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="25">
        <StackPanel VerticalAlignment="Stretch">
            <!-- Title -->
            <TextBlock Text="Calcul Inversé" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#1F2A44"
                       TextAlignment="Center"
                       Margin="0,0,0,25"/>

            <!-- Marge Nette Cible -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Marge nette cible (%):" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtMargeNette" 
                         Text="25" 
                         FontSize="14"
                         Padding="12,10"
                         Background="White"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         Foreground="#1F2A44"/>
                <TextBlock Text="Définir le pourcentage de marge nette souhaitée"
                           FontSize="11"
                           Foreground="#7F8FA3"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Marge Brute Cible (Optionnel) -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="Marge brute minimale (%) [Optionnel]:" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtMargeBrute" 
                         Text="" 
                         FontSize="14"
                         Padding="12,10"
                         Background="White"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         Foreground="#1F2A44"/>
                <TextBlock Text="Laissez vide pour ne pas appliquer de contrainte"
                           FontSize="11"
                           Foreground="#7F8FA3"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Boutons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button x:Name="btnOK" 
                        Content="Calculer" 
                        Width="140" 
                        Height="42"
                        Margin="0,0,12,0"
                        Background="#27AE60" 
                        Foreground="White" 
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnOK_Click"
                        Cursor="Hand"/>
                <Button x:Name="btnCancel" 
                        Content="Annuler" 
                        Width="140" 
                        Height="42"
                        Background="#95A5A6" 
                        Foreground="White" 
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnCancel_Click"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
