<Window x:Class="CalculatriceMargeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculatrice de Marge" 
        Height="720" Width="780" 
        Background="#F0F3F7" 
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#2ECC71"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F39C12"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#9B59B6"/>
        <SolidColorBrush x:Key="GreyBrush" Color="#95A5A6"/>
        
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top" Background="White" Padding="5,3" FontSize="11">
            <MenuItem Header="Fichier" Padding="8,4">
                <MenuItem Header="Sauvegarder l'historique" Click="MenuSauvegarder_Click"/>
                <MenuItem Header="Quitter" Click="MenuQuitter_Click"/>
            </MenuItem>
            <MenuItem Header="Historique" Padding="8,4">
                <MenuItem Header="Afficher/Masquer" Click="MenuHistorique_Click"/>
            </MenuItem>
            <MenuItem Header="Gestion BD" Padding="8,4">
                <MenuItem Header="🗄️ Gestion base de données" Click="MenuDatabase_Click"/>
                <Separator/>
                <MenuItem Header="Préférences" Click="MenuPreferences_Click"/>
            </MenuItem>
            <MenuItem Header="Affichage" Padding="8,4">
                <MenuItem Header="Thèmes">
                    <MenuItem Header="Clair" Click="MenuTheme_Click" Tag="Light"/>
                    <MenuItem Header="Sombre" Click="MenuTheme_Click" Tag="Dark"/>
                </MenuItem>
                <MenuItem Header="Langue">
                    <MenuItem Header="Français" Click="MenuLanguage_Click" Tag="fr"/>
                    <MenuItem Header="English" Click="MenuLanguage_Click" Tag="en"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Aide" Padding="8,4">
                <MenuItem Header="Guide d'utilisation" Click="MenuGuide_Click"/>
                <MenuItem Header="À propos" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                
                <!-- TITRE -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Titre" Style="{StaticResource Label}"/>
                        <TextBox x:Name="txtTitre" Margin="0"/>
                    </StackPanel>
                </Border>

                <!-- ENTRÉES ET PARAMÈTRES -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- GAUCHE: Entrées -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Entrées" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Déboursé sec (€)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="txtDebourse"/>
                            <TextBlock Text="Prix revient (€)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="txtRevient" IsReadOnly="True" Background="#ECF0F1"/>
                            <TextBlock Text="Prix vente HT (€)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="txtVente" TextChanged="txtVente_TextChanged"/>
                            <TextBlock Text="Remise (%)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="txtRemise" Text="0" TextChanged="txtRemise_TextChanged"/>
                            <TextBlock Text="Prix après remise (€)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="txtPrixApresRemise" IsReadOnly="True" Background="#ECF0F1" Margin="0"/>
                        </StackPanel>
                    </Border>

                    <!-- DROITE: Paramètres -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Paramètres" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Frais généraux" Style="{StaticResource Label}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtFrais" Text="25" Grid.Column="0" Margin="0"/>
                                <ComboBox x:Name="cmbFraisMode" Grid.Column="2" SelectedIndex="0" Margin="0">
                                    <ComboBoxItem Content="%"/>
                                    <ComboBoxItem Content="€"/>
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="TVA (%)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="txtTVA" Text="20"/>
                            
                            <TextBlock Text="Presets" Style="{StaticResource SectionTitle}" Margin="0,6,0,8"/>
                            <ComboBox x:Name="cmbPresets" SelectedIndex="0">
                                <ComboBoxItem Content="Standard (20% TVA, 25% FG)"/>
                                <ComboBoxItem Content="Réduit (5.5% TVA, 8% FG)"/>
                                <ComboBoxItem Content="Service (10% TVA, 15% FG)"/>
                            </ComboBox>
                            <Button Content="✓ Appliquer" Background="{StaticResource SuccessBrush}" Style="{StaticResource Btn}" Margin="0" Click="btnApplyPreset_Click"/>

                            <TextBlock Text="Presets personnalisés" Style="{StaticResource SectionTitle}" Margin="0,10,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button x:Name="btnSavePreset" Content="➕ Ajouter" Background="#2ECC71" Style="{StaticResource Btn}" Width="90" Margin="0,0,6,0" Click="btnSavePreset_Click"/>
                                <Button x:Name="btnApplyCustomPreset" Content="✓ Charger" Background="#2980B9" Style="{StaticResource Btn}" Width="90" Margin="0,0,6,0" Click="btnApplyCustomPreset_Click"/>
                                <Button x:Name="btnDeletePreset" Content="🗑 Supprimer" Background="#E74C3C" Style="{StaticResource Btn}" Width="90" Click="btnDeletePreset_Click"/>
                            </StackPanel>
                            <ListBox x:Name="lstCustomPresets" Height="110" DisplayMemberPath="Name" SelectionChanged="lstCustomPresets_SelectionChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- BOUTONS -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnCalculer" Content="📊 Calculer" Background="{StaticResource PrimaryBrush}" Style="{StaticResource Btn}" Click="btnCalculer_Click" Grid.Column="0" Margin="0,0,3,0"/>
                        <Button x:Name="btnCalculInverse" Content="⟷ Inversé" Background="{StaticResource InfoBrush}" Style="{StaticResource Btn}" Click="btnCalculInverse_Click" Grid.Column="1" Margin="2,0,2,0"/>
                        <Button x:Name="btnReset" Content="⟲ Reset" Background="{StaticResource GreyBrush}" Style="{StaticResource Btn}" Click="btnReset_Click" Grid.Column="2" Margin="2,0,2,0"/>
                        <Button x:Name="btnExportCSV" Content="📥 CSV" Background="#2980B9" Style="{StaticResource Btn}" Click="btnExportCSV_Click" Grid.Column="3" Margin="3,0,0,0"/>
                        <Button x:Name="btnExportHTML" Content="🌐 HTML" Background="#8E44AD" Style="{StaticResource Btn}" Click="btnExportHTML_Click" Grid.Column="4" Margin="3,0,0,0"/>
                    </Grid>
                </Border>

                <!-- INTEROP & EXPORTS AVANCÉS -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Interop &amp; exports" Style="{StaticResource SectionTitle}"/>
                        <WrapPanel ItemHeight="32" ItemWidth="150" Margin="0,4,0,0">
                            <Button x:Name="btnExportStats" Content="📈 Stats CSV" Background="#16A085" Style="{StaticResource Btn}" Width="140" Margin="0,0,6,6" Click="btnExportStats_Click"/>
                            <Button x:Name="btnCopyLast" Content="📋 Copier dernier" Background="#34495E" Style="{StaticResource Btn}" Width="140" Margin="0,0,6,6" Click="btnCopyLast_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- RÉSULTATS -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📈 Résultats" Style="{StaticResource SectionTitle}"/>
                        
                        <!-- 3 indicateurs + 2 marges -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#EBF5FB" Padding="10" CornerRadius="4" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Text="Déboursé sec" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="txtRecapDS" FontSize="14" FontWeight="Bold" Foreground="#3498DB" Text="0,00 €"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#FEF5E7" Padding="10" CornerRadius="4" Margin="3,0,3,0">
                                <StackPanel>
                                    <TextBlock Text="Prix revient" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="txtPrixRevient" FontSize="14" FontWeight="Bold" Foreground="#F39C12" Text="0,00 €"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#E8F8F5" Padding="10" CornerRadius="4" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Prix HT" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="txtRecapHT" FontSize="14" FontWeight="Bold" Foreground="#2ECC71" Text="0,00 €"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Prix TTC + Remise -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#E8DAEF" Padding="10" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="Prix TTC" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="txtRecapTTC" FontSize="14" FontWeight="Bold" Foreground="#9B59B6" Text="0,00 €"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#FFF4E5" Padding="10" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="Remise appliquée" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="txtRecapRemise" FontSize="14" FontWeight="Bold" Foreground="#E67E22" Text="Pas de remise"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- MARGES CÔTE À CÔTE -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FADBD8" Padding="12" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="💸 Marge brute" FontSize="11" Foreground="#C0392B" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtMargeBrute" FontSize="22" FontWeight="Bold" Foreground="#E74C3C" Text="0,00%" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#D5F4E6" Padding="12" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="💰 Marge nette" FontSize="11" Foreground="#16A085" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtMargeNette" FontSize="22" FontWeight="Bold" Foreground="#27AE60" Text="0,00%" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- TABLEAU DE BORD -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📊 Tableau de bord" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Column="0" Grid.Row="0" Background="#EBF5FB" Padding="10" CornerRadius="4" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="Nb calculs" Style="{StaticResource Label}"/>
                                    <TextBlock x:Name="txtDashCalculs" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Text="--"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Grid.Row="0" Background="#E8F8F5" Padding="10" CornerRadius="4" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="CA TTC total" Style="{StaticResource Label}"/>
                                    <TextBlock x:Name="txtDashCA" FontSize="18" FontWeight="Bold" Foreground="#16A085" Text="--"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Grid.Row="0" Background="#FEF5E7" Padding="10" CornerRadius="4" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="Marge nette moyenne" Style="{StaticResource Label}"/>
                                    <TextBlock x:Name="txtDashMargeNetteMoy" FontSize="18" FontWeight="Bold" Foreground="#E67E22" Text="--"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="0" Grid.Row="1" Background="#E8DAEF" Padding="10" CornerRadius="4" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="Marge nette min / max" Style="{StaticResource Label}"/>
                                    <TextBlock x:Name="txtDashMargeNetteMinMax" FontSize="18" FontWeight="Bold" Foreground="#8E44AD" Text="--"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Grid.Row="1" Background="#FADBD8" Padding="10" CornerRadius="4" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="Marge brute moyenne" Style="{StaticResource Label}"/>
                                    <TextBlock x:Name="txtDashMargeBruteMoy" FontSize="18" FontWeight="Bold" Foreground="#C0392B" Text="--"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Grid.Row="1" Background="#ECF0F1" Padding="10" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="Dernier titre" Style="{StaticResource Label}"/>
                                    <TextBlock x:Name="txtDashLastTitle" FontSize="16" FontWeight="SemiBold" Foreground="#2C3E50" Text="--"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- HISTORIQUE -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📋 Historique" Style="{StaticResource SectionTitle}"/>
                        <ListBox x:Name="lstHistorique" Height="70" Background="White" BorderBrush="#D5DBDB" BorderThickness="1" FontSize="10" Padding="6" MouseDoubleClick="lstHistorique_MouseDoubleClick" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📋 Copier dans le presse-papiers" Click="lstHistorique_CopyToClipboard"/>
                                    <Separator/>
                                    <MenuItem Header="📄 Exporter CSV" Click="lstHistorique_ExportCSV"/>
                                    <MenuItem Header="📊 Exporter HTML" Click="lstHistorique_ExportHTML"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button x:Name="btnStatistiques" Content="�️ Gestion Base de Données" Width="200" Height="28" FontSize="11" Background="#3498DB" Foreground="White" FontWeight="SemiBold" Click="btnStatistiques_Click" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
