<Window x:Class="CalculatriceMargeWPF.Views.DatabaseManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion de la base de données SQLite" 
        Height="650" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="700"
        MinHeight="550"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🗄️ Gestion de la base de données" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Gérez votre historique SQLite : sauvegarde, restauration et statistiques"
                       FontSize="12"
                       Foreground="#7F8C8D"/>
        </StackPanel>

        <!-- Contenu principal -->
        <TabControl Grid.Row="1" Margin="0,0,0,15">
            <!-- Onglet Informations -->
            <TabItem Header="📊 Informations">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Informations générales"/>
                        
                        <Border Background="White" 
                                Padding="15" 
                                CornerRadius="5" 
                                BorderBrush="#BDC3C7" 
                                BorderThickness="1"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Emplacement :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtDbPath" Margin="0,5" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Taille du fichier :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDbSize" Margin="0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Dernière modification :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtDbLastModified" Margin="0,5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Nombre d'entrées :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtDbEntries" Margin="0,5"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Version SQLite :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtSqliteVersion" Margin="0,5"/>
                            </Grid>
                        </Border>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Statistiques"/>
                        
                        <Border Background="White" 
                                Padding="15" 
                                CornerRadius="5" 
                                BorderBrush="#BDC3C7" 
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cumul marges brutes :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtTotalMargeBrute" Margin="0,5" Foreground="#27AE60"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Cumul marges nettes :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtTotalMargeNette" Margin="0,5" Foreground="#27AE60"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Marge brute moyenne :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtAvgMargeBrute" Margin="0,5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Marge nette moyenne :" FontWeight="Bold" Margin="0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtAvgMargeNette" Margin="0,5"/>
                            </Grid>
                        </Border>

                        <Button Content="🔄 Actualiser les informations" 
                                Style="{StaticResource ActionButton}"
                                Click="btnRefreshInfo_Click"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Sauvegarde -->
            <TabItem Header="💾 Sauvegarde">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Sauvegarder la base de données"/>
                        
                        <TextBlock Style="{StaticResource InfoText}" Margin="0,0,0,15">
                            <Run Text="Créez une copie de sauvegarde de votre base de données. "/><LineBreak/>
                            <Run Text="Le fichier sera sauvegardé avec la date et l'heure actuelles."/>
                        </TextBlock>

                        <Button Content="💾 Créer une sauvegarde" 
                                Style="{StaticResource ActionButton}"
                                Click="btnBackup_Click"
                                HorizontalAlignment="Left"
                                Width="200"/>

                        <Separator Margin="0,30"/>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Sauvegardes automatiques"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="chkAutoBackup" 
                                      Content="Activer les sauvegardes automatiques"
                                      VerticalAlignment="Center"
                                      Checked="chkAutoBackup_Changed"
                                      Unchecked="chkAutoBackup_Changed"/>
                        </StackPanel>

                        <StackPanel x:Name="pnlAutoBackupSettings" Margin="20,10,0,0" IsEnabled="False">
                            <TextBlock Text="Fréquence :" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbBackupFrequency" Width="200" HorizontalAlignment="Left">
                                <ComboBoxItem Content="Quotidienne" IsSelected="True"/>
                                <ComboBoxItem Content="Hebdomadaire"/>
                                <ComboBoxItem Content="Mensuelle"/>
                            </ComboBox>

                            <TextBlock Text="Nombre de sauvegardes à conserver :" FontWeight="Bold" Margin="0,15,0,5"/>
                            <TextBox x:Name="txtBackupRetention" Width="100" HorizontalAlignment="Left" Text="5"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Restauration -->
            <TabItem Header="📥 Restauration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Restaurer depuis une sauvegarde"/>
                        
                        <Border Background="#FFF3CD" 
                                Padding="10" 
                                CornerRadius="5" 
                                BorderBrush="#FFC107" 
                                BorderThickness="1"
                                Margin="0,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="#856404">
                                <Run Text="⚠️ Attention : "/><Run FontWeight="Bold" Text="La restauration remplacera votre base de données actuelle."/><LineBreak/>
                                <Run Text="Une sauvegarde automatique de la base actuelle sera créée avant la restauration."/>
                            </TextBlock>
                        </Border>

                        <Button Content="📥 Restaurer depuis un fichier" 
                                Style="{StaticResource ActionButton}"
                                Click="btnRestore_Click"
                                HorizontalAlignment="Left"
                                Width="250"/>

                        <Separator Margin="0,30"/>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Importer depuis l'ancien format"/>
                        
                        <TextBlock Style="{StaticResource InfoText}" Margin="0,0,0,15">
                            <Run Text="Si vous avez un ancien fichier historique.txt, vous pouvez l'importer dans SQLite."/>
                        </TextBlock>

                        <Button Content="📄 Importer historique.txt" 
                                Style="{StaticResource ActionButton}"
                                Click="btnImportText_Click"
                                HorizontalAlignment="Left"
                                Width="250"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Maintenance -->
            <TabItem Header="🔧 Maintenance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Maintenance de la base"/>
                        
                        <TextBlock Style="{StaticResource InfoText}" Margin="0,0,0,15">
                            <Run Text="Optimisez les performances de votre base de données avec ces outils de maintenance."/>
                        </TextBlock>

                        <Button Content="🔧 Optimiser la base (VACUUM)" 
                                Style="{StaticResource ActionButton}"
                                Click="btnVacuum_Click"
                                HorizontalAlignment="Left"
                                Width="250"
                                Margin="0,0,0,10"/>

                        <TextBlock Text="Compacte la base et récupère l'espace disque inutilisé."
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="5,0,0,20"/>

                        <Button Content="🔍 Vérifier l'intégrité" 
                                Style="{StaticResource ActionButton}"
                                Click="btnIntegrity_Click"
                                HorizontalAlignment="Left"
                                Width="250"
                                Margin="0,0,0,10"/>

                        <TextBlock Text="Vérifie que la base de données n'est pas corrompue."
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="5,0,0,20"/>

                        <Button Content="📊 Analyser la base" 
                                Style="{StaticResource ActionButton}"
                                Click="btnAnalyze_Click"
                                HorizontalAlignment="Left"
                                Width="250"
                                Margin="0,0,0,10"/>

                        <TextBlock Text="Met à jour les statistiques pour améliorer les performances."
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="5,0,0,30"/>

                        <Separator Margin="0,10,0,20"/>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Zone dangereuse" Foreground="#E74C3C"/>
                        
                        <Border Background="#F8D7DA" 
                                Padding="10" 
                                CornerRadius="5" 
                                BorderBrush="#F5C6CB" 
                                BorderThickness="1"
                                Margin="0,0,0,15">
                            <TextBlock TextWrapping="Wrap" Foreground="#721C24">
                                <Run Text="⚠️ Actions irréversibles"/><LineBreak/>
                                <Run Text="Ces actions supprimeront définitivement vos données."/>
                            </TextBlock>
                        </Border>

                        <Button Content="🗑️ Vider complètement l'historique" 
                                Style="{StaticResource DangerButton}"
                                Click="btnClearAll_Click"
                                HorizontalAlignment="Left"
                                Width="250"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Éléments -->
            <TabItem Header="📋 Éléments">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Liste des éléments"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="txtSearchItems" Width="250" Text="Rechercher par titre..." TextChanged="txtSearchItems_TextChanged" Foreground="#999"/>
                            <Button Content="🔍 Rechercher" Style="{StaticResource ActionButton}" Click="btnSearchItems_Click" Width="150" Margin="10,0,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="dgElements" 
                                  AutoGenerateColumns="False" 
                                  Height="400"
                                  BorderBrush="#BDC3C7"
                                  BorderThickness="1"
                                  Background="White"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Titre" Binding="{Binding Titre}" Width="150"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding DateCalcul, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                                <DataGridTextColumn Header="Déboursé" Binding="{Binding DebourseSec, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Frais G." Binding="{Binding FraisGeneraux, StringFormat=F2}" Width="80"/>
                                <DataGridTextColumn Header="Prix HT" Binding="{Binding PrixVenteHT, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Remise %" Binding="{Binding RemisePourcentage, StringFormat=F2}" Width="70"/>
                                <DataGridTextColumn Header="Prix TTC" Binding="{Binding PrixVenteTTC, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="TVA %" Binding="{Binding TVA, StringFormat=F2}" Width="60"/>
                                <DataGridTextColumn Header="Marge B." Binding="{Binding MargeBrute, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Marge B %" Binding="{Binding MargeBrutePourcentage, StringFormat=F2}" Width="80"/>
                                <DataGridTextColumn Header="Marge N." Binding="{Binding MargeNette, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Marge N %" Binding="{Binding MargeNettePourcentage, StringFormat=F2}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="📥 Charger" 
                                    Style="{StaticResource ActionButton}"
                                    Click="btnLoadElement_Click"
                                    Width="150"
                                    Margin="0,0,5,0"/>
                            <Button Content="📄 Exporter" 
                                    Style="{StaticResource ActionButton}"
                                    Click="btnExportElement_Click"
                                    Width="150"
                                    Margin="5,0,5,0"/>
                            <Button Content="📋 Copier" 
                                    Style="{StaticResource ActionButton}"
                                    Click="btnCopyElement_Click"
                                    Width="150"/>
                        </StackPanel>

                        <TextBlock Text="💡 Double-cliquez sur un élément pour voir les détails complets" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D" 
                                   Margin="0,15,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Pied de page -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Fermer" 
                    Style="{StaticResource ActionButton}"
                    Click="btnClose_Click"
                    Width="100"/>
        </StackPanel>
    </Grid>
</Window>
